#!/bin/sh
# Независимый тумблер профиля (мульти-режим):
#   /cgi-bin/connect?name=X&on=1   — включить профиль X (поднять его инстанс)
#   /cgi-bin/connect?name=X&on=0   — выключить профиль X
# Возвращается мгновенно, работа в фоне.
PATH=/opt/bin:/opt/sbin:/sbin:/bin:/usr/sbin:/usr/bin
export PATH
printf "Content-Type: application/json; charset=utf-8\r\n\r\n"

NAME=$(echo "$QUERY_STRING" | sed -n 's/.*name=\([^&]*\).*/\1/p' | tr -cd 'A-Za-z0-9._-')
ON=$(echo "$QUERY_STRING" | sed -n 's/.*on=\([^&]*\).*/\1/p' | tr -cd '01')
[ -z "$NAME" ] && { echo '{"error":"need name"}'; exit 0; }

if [ "$ON" = "1" ]; then
  ( /opt/sbin/invnetctl enable "$NAME" >/opt/var/log/invnet-action.log 2>&1 </dev/null & ) >/dev/null 2>&1
  echo "{\"ok\":true,\"status\":\"enabling\",\"profile\":\"$NAME\"}"
else
  ( /opt/sbin/invnetctl disable "$NAME" >/opt/var/log/invnet-action.log 2>&1 </dev/null & ) >/dev/null 2>&1
  echo "{\"ok\":true,\"status\":\"disabling\",\"profile\":\"$NAME\"}"
fi
