#!/bin/sh
# Агрегированный лог: последние действия + логи всех запущенных профилей.
# В мультипрофиле openvpn пишет в /opt/var/log/invnet-<profile>.log,
# поэтому старый единый invnet.log пустой — собираем по слотам.
PATH=/opt/bin:/opt/sbin:/sbin:/bin:/usr/sbin:/usr/bin
export PATH
printf "Content-Type: text/plain; charset=utf-8\r\n\r\n"

LOGDIR=/opt/var/log
RUN=/opt/var/run/invnet
ANY=0

if [ -s "$LOGDIR/invnet-action.log" ]; then
  echo "===== последние действия ====="
  tail -12 "$LOGDIR/invnet-action.log"
  ANY=1
fi

for sf in "$RUN"/*.slot; do
  [ -f "$sf" ] || continue
  pr=$(basename "$sf" .slot)
  LF="$LOGDIR/invnet-$pr.log"
  [ -f "$LF" ] || continue
  echo
  echo "===== $pr (slot $(cat "$sf" 2>/dev/null)) ====="
  tail -20 "$LF" | grep -vE '^VERIFY'
  ANY=1
done

if [ -s "$LOGDIR/invnet.log" ]; then
  echo
  echo "===== общий ====="
  tail -15 "$LOGDIR/invnet.log"
  ANY=1
fi

[ "$ANY" = 0 ] && echo "лог пуст (нет запущенных профилей)"
