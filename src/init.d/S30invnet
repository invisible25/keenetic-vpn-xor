#!/bin/sh
# VPN+XOR — тонкая обёртка над менеджером мульти-профилей.
export PATH=/opt/bin:/opt/sbin:/sbin:/bin:/usr/sbin:/usr/bin
MGR=/opt/sbin/invnetctl

case "$1" in
  start)   "$MGR" reconcile ;;   # поднять все профили с enabled=true
  stop)    "$MGR" stopall ;;
  restart) "$MGR" stopall; sleep 1; "$MGR" reconcile ;;
  apply)   "$MGR" apply ;;
  status)  "$MGR" status ;;
  *) echo "usage: $0 {start|stop|restart|apply|status}"; exit 1 ;;
esac
